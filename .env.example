# Copy to .env and fill in. The app runs without these (AI + alerts degrade gracefully).

# Claude (AI summaries). Without it, a heuristic fallback summary is used.
ANTHROPIC_API_KEY=

# Twilio (WhatsApp / SMS alerts). Sandbox is dev-only; production WhatsApp
# needs an approved Business sender + template messages.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=
